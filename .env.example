# Resend (audit diagnostic emails, Skin AI waitlist). Without it, submissions are
# still accepted and the diagnostic still renders, but no email gets sent.
RESEND_API_KEY=
# Where audit/waitlist submissions are delivered.
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL=site@example.com

# Public site URL (used for sitemap, canonical, OG).
NEXT_PUBLIC_SITE_URL=https://bamidele.example.com

# Cal.com booking link, e.g. "bamidele/intro-call". Used on /okoh and in the
# /audit results (paid diagnostic call).
NEXT_PUBLIC_CAL_LINK=

# Paid diagnostic call price shown in the /audit results, e.g. "15,000"
NEXT_PUBLIC_AUDIT_PRICE_NGN=

# AlphaWGA Aso-Oke pages (/, /offers, /products, /writing, /contact,
# /scorecard): Cal.com diagnostic-call booking link (free intro call, no
# payment gate). The site only links out.
NEXT_PUBLIC_BOOKING_URL=

# Where new /scorecard leads get an internal notification. Falls back to
# CONTACT_TO_EMAIL, then hello@example.com. Uses the existing RESEND_API_KEY.
SCORECARD_NOTIFY_EMAIL=

# Paystack (paid /audit diagnostic call gate). Cal.com has no native Paystack
# app, so payment is handled directly on-site via Paystack's inline checkout
# before the Cal.com embed is revealed. Get both from the Paystack dashboard
# under Settings > API Keys & Webhooks. Use test keys (pk_test_/sk_test_)
# until the business is verified for live payments.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Postgres (ERP waitlist + scorecard lead storage), via Prisma. Vercel
# Postgres injects this automatically once storage is linked in the
# dashboard. Without it, the forms still accept submissions and return
# success, but nothing is saved.
DATABASE_URL=
# Same database, non-pooled connection (no "-pooler" in the host). Used only
# for running `prisma migrate` — Neon's pooled endpoint isn't reliable for
# migrations.
DIRECT_URL=

# Basic auth for the internal CRM dashboard at /admin/crm.
# Set a strong password. Leave blank to disable CRM access.
ADMIN_PASSWORD=

# Microsoft Clarity (heatmaps, scroll maps, session recordings). Get the
# project ID from clarity.microsoft.com > Settings > Setup > Install manually
# (it's the id in the tag URL, e.g. clarity.ms/tag/xxxxxxxxxx). Leave blank to
# disable — no script gets injected without it.
NEXT_PUBLIC_CLARITY_PROJECT_ID=
