# Resend (contact form). Without it, the form falls back to a mailto handoff.
RESEND_API_KEY=
# Where contact submissions are delivered.
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL=site@example.com

# Public site URL (used for sitemap, canonical, OG).
NEXT_PUBLIC_SITE_URL=https://bamidele.example.com

# Cal.com booking link, e.g. "bamidele/intro-call"
NEXT_PUBLIC_CAL_LINK=
