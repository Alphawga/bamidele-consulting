# Resend (audit diagnostic emails, Skin AI waitlist). Without it, submissions are
# still accepted and the diagnostic still renders, but no email gets sent.
RESEND_API_KEY=
# Where audit/waitlist submissions are delivered.
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL=site@example.com

# Public site URL (used for sitemap, canonical, OG).
NEXT_PUBLIC_SITE_URL=https://bamidele.example.com

# Cal.com booking link, e.g. "bamidele/intro-call". Used on /okoh and in the
# /audit results (paid diagnostic call).
NEXT_PUBLIC_CAL_LINK=

# Paid diagnostic call price shown in the /audit results, e.g. "15,000"
NEXT_PUBLIC_AUDIT_PRICE_NGN=

# AlphaWGA Aso-Oke pages (/, /offers, /products, /writing, /contact,
# /scorecard): Cal.com diagnostic-call booking link. Paystack payment is
# attached on the Cal.com side; the site only links out.
NEXT_PUBLIC_BOOKING_URL=

# Where new /scorecard leads get an internal notification. Falls back to
# CONTACT_TO_EMAIL, then hello@example.com. Uses the existing RESEND_API_KEY.
SCORECARD_NOTIFY_EMAIL=

# Supabase (ERP waitlist + scorecard lead storage). Without these, the forms
# still accept submissions and return success, but nothing is saved.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
